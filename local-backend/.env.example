# Copy this file to .env and fill in the real values.
# .env is gitignored — never commit the actual .env file.

# SQL Server connection
DB_SERVER=192.168.x.x
DB_PORT=1433
DB_USER=SA
DB_PASSWORD=your_password_here
DB_NAME=ForNetOkan

# Admin dashboard password (used by /staff-admin route)
ADMIN_PASS=your_admin_password_here

# API key — all requests from the frontend must include X-API-Key: <this value>
# Generate a strong random string, e.g: openssl rand -hex 32
API_KEY=your_api_key_here
